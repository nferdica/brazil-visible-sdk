{
  "name": "@bracc/sdk",
  "version": "0.1.0",
  "description": "SDK TypeScript unificado para acesso a 93+ fontes de dados publicos brasileiros",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "biome check src/ tests/",
    "format": "biome check --write src/ tests/",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "brazil",
    "dados-abertos",
    "open-data",
    "governo",
    "transparencia",
    "api",
    "ibge",
    "datasus",
    "tse",
    "receita-federal"
  ],
  "author": "Brazilian Accelerationism <contato@bracc.co>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/brazilvisible/brazil-visible-sdk.git"
  },
  "bugs": {
    "url": "https://github.com/brazilvisible/brazil-visible-sdk/issues"
  },
  "homepage": "https://bracc.co",
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9",
    "@types/node": "^25.3.5",
    "msw": "^2.7",
    "tsup": "^8.0",
    "typescript": "^5.5",
    "vitest": "^3.0"
  },
  "dependencies": {
    "csv-parse": "^6.1.0"
  }
}
